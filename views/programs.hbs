<!-- Page header -->
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-end">
      <div class="col">
        <!-- Page pre-title -->
        <div class="page-pretitle">
          Programs
        </div>
        <h2 class="page-title">
          Manage Programs
        </h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <a href="#" class="btn btn-primary btn-5 d-none d-sm-inline-block" data-bs-toggle="modal"
            data-bs-target="#modal-new-program">
            <i class="ti ti-plus icon icon-2"></i>
            Create new program
          </a>
          <a href="#" class="btn btn-primary btn-6 d-sm-none btn-icon" data-bs-toggle="modal"
            data-bs-target="#modal-new-program" aria-label="Create new program">
            <i class="ti ti-plus icon icon-2"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
{{#if programs.length}}

<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      {{#each programs}}
      <div class="col-sm-6 col-lg-4" data-program-id="{{this._id}}">
        <div class="card">

          <div class="card-img-top"
            style="height:160px; background-image:url('{{this.imageUrl}}'); background-size:cover; background-position:center;">
          </div>

          <div class="card-body">
            <h3 class="card-title mb-1">{{this.title}}</h3>
            <div class="text-muted mb-3">
              {{this.duration}} · Age {{this.ageRange}}
            </div>
            <div class="text-muted mb-3">
              Created · {{formatDate this.createdAt}}
            </div>

            <div class="d-flex gap-2">

              <a href="/programs/{{this._id}}/view" class="btn btn-primary btn-sm w-100">
                View
              </a>

              <button class="btn btn-secondary btn-sm w-100" onclick="getEditProgramModal(this)" data-id="{{this._id}}">
                Edit
              </button>

              <button class="btn btn-outline-danger btn-sm w-100 delete-program" data-id="{{this._id}}">
                Delete
              </button>
            </div>
          </div>

        </div>
      </div>

      {{/each}}
    </div>
  </div>
</div>

{{else}}
<div class="container-xl my-auto">
  <div class="empty">
    <div class="empty-img">
      <i class="ti ti-mood-empty img" style="font-size: 8rem;"></i>
    </div>
    <p class="empty-title">No results found</p>
    <p class="empty-subtitle text-secondary">
      Try adjusting your search or filter to find what you're looking for.
    </p>
    <div class="empty-action">
      <a href="#" class="btn btn-primary d-none d-sm-inline-block" data-bs-toggle="modal"
        data-bs-target="#modal-new-program">
        <i class="ti ti-plus icon"></i>
        Add your first program
      </a>
    </div>
  </div>
</div>
{{/if}}

{{> emptyProgramModal }}

<script>
  

  window.getEditProgramModal = function (elem) {
    const programId = $(elem).attr("data-id");

    const modalExists = $(document).find(`#button-${programId}`).length > 0;

    if (modalExists) {
      $(`#button-${programId}`).remove();
      $(`#modal-${programId}`).remove();
    }

    $.ajax({
      url: `/getEditProgramModal/${programId}`,
      type: 'GET',
      contentType: 'application/json',
      success: function (response) {
        $("footer").before(response);
        $(`#button-${programId}`).trigger("click");
      },
      error: function (xhr, status, error) {
        alert(xhr.responseText);
      }
    });
  };

  $(document).on('click', '.delete-program', function () {
    const programId = $(this).attr('data-id');

    if (!programId) return;

    const confirmed = confirm('Are you sure you want to delete this program?');
    if (!confirmed) return;

    $.ajax({
      url: `/programs/${programId}/delete`,
      type: 'POST',
      contentType: 'application/json',
      success: function () {
        const card = $(document).find(`[data-program-id="${programId}"]`);
        if (card.length) {
          card.remove();
        }
      },
      error: function (xhr) {
        alert(xhr.responseText || 'Failed to delete program');
      }
    });
  });
</script>