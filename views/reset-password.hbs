<div class="page page-center">
    <div class="container container-tight py-4">
        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">Reset password</h2>
                {{#if note}}
                    <div class="alert alert-danger" role="alert">{{note}}</div>
                {{/if}}
                {{#if token}}
                    <form method="POST" action="/reset-password" autocomplete="off" novalidate>
                        <input type="hidden" name="token" value="{{token}}">
                        <div class="mb-3">
                            <label class="form-label">New password</label>
                            <input type="password" name="password" class="form-control" autocomplete="new-password" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Confirm password</label>
                            <input type="password" name="confirmPassword" class="form-control" autocomplete="new-password" required>
                        </div>
                        <div class="form-footer">
                            <button type="submit" class="btn btn-primary w-100">Reset password</button>
                        </div>
                    </form>
                {{else}}
                    <div class="mt-2 text-center">
                        <a href="/forgot-password">Request a new reset link</a>
                    </div>
                {{/if}}
                <div class="mt-3 text-center">
                    <a href="/login">Back to login</a>
                </div>
            </div>
        </div>
    </div>
</div>
