<div class="page page-center">
    <div class="container container-tight py-4">
        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">Sign in to your account</h2>
                {{#if note}}
                    <div class="alert alert-danger" role="alert">{{note}}</div>
                {{/if}}
                {{#if success}}
                    <div id="loginSuccessMessage" class="d-none">{{success}}</div>
                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            const message = document.getElementById('loginSuccessMessage')?.textContent.trim();
                            if (message && window.showAdminToast) showAdminToast(message);
                        });
                    </script>
                {{/if}}
                <form method="POST" action="/login" autocomplete="off" novalidate>
                    <div class="mb-3">
                        <label class="form-label">Email address</label>
                        <input type="email" name="email" class="form-control" placeholder="your@email.com" autocomplete="email" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" name="password" class="form-control" placeholder="Enter your password" autocomplete="current-password" required>
                    </div>
                    <div class="mb-2">
                        <a href="/forgot-password">Forgot password?</a>
                    </div>
                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100">Sign in</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
