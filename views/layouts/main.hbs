<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{title}}</title>

  <!-- CSS files -->
  <link href="/tabler/css/tabler.min.css?1692870487" rel="stylesheet" />
  <link href="/tabler/css/tabler-flags.min.css?1692870487" rel="stylesheet" />
  <link href="/tabler/css/tabler-payments.min.css?1692870487" rel="stylesheet" />
  <link href="/tabler/css/tabler-vendors.min.css?1692870487" rel="stylesheet" />
  <link href="/tabler/css/demo.min.css?1692870487" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/theme/dark.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />

  <style>
    @import url('https://rsms.me/inter/inter.css');

    :root {
      --tblr-font-sans-serif: 'Inter Var', -apple-system, BlinkMacSystemFont, San Francisco, Segoe UI, Roboto, Helvetica Neue, sans-serif;
    }

    body {
      font-feature-settings: "cv03", "cv04", "cv11";
    }

    .navbar-vertical.navbar-expand-lg {
      scrollbar-width: none;
    }

    .navbar-vertical.navbar-expand-lg::-webkit-scrollbar {
      display: none;
    }

    .tooltip {
      z-index: 1050;
    }

    .card-hover {
      cursor: pointer;
    }

    .card-hover:hover {
      background-color: rgba(0, 123, 255, 0.1);
      transition: background-color 0.3s ease;
    }

    .no-caret::after {
      display: none !important;
    }

    .file {
      border-radius: 4px;
      cursor: pointer;
    }

    .file:hover,
    .file.selected {
      background-color: rgba(0, 123, 255, 0.1);
      color: var(--tbl-text);
    }

    .ticket-icon-wrapper {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .ticket-alert-dot {
      position: absolute;
      top: -4px;
      right: -4px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #fa5252;
      box-shadow: 0 0 0 2px var(--tblr-navbar-bg, #fff);
    }

    .collapsed-sidebar .navbar-brand-image {
      height: auto;
    }

    @media (min-width: 991.98px) {
      .collapsed-sidebar {
        width: 71px;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 1020;
        align-items: flex-start;
        transition: transform .3s;
        overflow-y: scroll;
        padding: 0;
        --tblr-navbar-bg: var(--tblr-bg-surface);
        align-items: stretch;
        min-height: 3.5rem;
        box-shadow: inset 0 calc(-1* var(--tblr-navbar-border-width)) 0 0 var(--tblr-navbar-border-color);
        background: var(--tblr-navbar-bg);
        border-right: 1px solid var(--tblr-border-color);
        scrollbar-width: none;
      }

      .collapsed-sidebar.collapsed {
        display: none;
      }

      .collapsed-sidebar>.container-fluid {}

      .collapsed-sidebar .nav-link-icon {
        margin: auto !important;
      }

      .collapsed-sidebar .navbar-brand {
        padding: .75rem 0;
        padding-left: 8px;
        justify-content: center;
      }

      .sidebar-toggler {
        position: fixed;
        left: 227px;
        top: 42px;
        z-index: 1045;
      }

      .ml-collapsed-sidebar {
        margin-left: 75px !important;
      }

      .sidebar-toggler.collapsed {
        left: 59px;
      }

      .sidebar-toggler>.svg-default {
        display: inline-block;
      }

      .sidebar-toggler>.svg-collapsed {
        display: none;
      }

      .sidebar-toggler.collapsed .svg-default {
        display: none;
      }

      .sidebar-toggler.collapsed .svg-collapsed {
        display: inline-block;
      }

    }
  </style>
</head>

