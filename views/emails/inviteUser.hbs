<div style="font-family: Arial, sans-serif; line-height: 1.6; color: #1f2937;">
  <h2>You’re invited to {{brandName}} Admin</h2>
  <p>Hi {{name}},</p>
  <p>You’ve been invited to access the {{brandName}} admin dashboard.</p>
  {{#if loginUrl}}
    <p><a href="{{loginUrl}}" style="color: #2563eb;">Open login page</a></p>
  {{/if}}
  {{#if resetLink}}
    <p><a href="{{resetLink}}" style="color: #2563eb;">Set / reset your password</a></p>
  {{/if}}
  <p>If you did not expect this invitation, you can ignore this email.</p>
  <p>Thanks,<br/>{{brandName}} Team</p>
</div>
