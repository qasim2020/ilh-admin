<div class="modal modal-blur fade" id="modal-{{program._id}}" tabindex="-1" style="display: none; padding-left: 0px;"
    aria-modal="true" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Program</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <div class="mb-3">
                    <label class="form-label">Program Image</label>
                    <div id="programImageBox{{program._id}}" class="border rounded d-flex align-items-center justify-content-center"
                        style="height: 150px; cursor: pointer;">
                        <img src="{{program.imageUrl}}"
                            style="height:100%; width:100%; object-fit:cover; border-radius:0.25rem;">
                    </div>
                    <input type="file" id="programImageInput{{program._id}}" name="programImage" accept="image/*"
                        style="display: none;">
                </div>

                <div class="mb-3">
                    <label class="form-label">Program Title</label>
                    <input type="text" name="title" class="form-control" value="{{program.title}}" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Gender</label>
                    <select name="gender" class="form-select" required>
                        <option value="">Select</option>
                        <option value="boys" {{#if (eq program.gender "boys" )}}selected{{/if}}>Boys</option>
                        <option value="girls" {{#if (eq program.gender "girls" )}}selected{{/if}}>Girls</option>
                        <option value="both" {{#if (eq program.gender "both" )}}selected{{/if}}>Both</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea id="programDescription{{program._id}}" name="description" class="form-control"
                        rows="10">{{{program.description}}}</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Special Features</label>
                    <textarea id="specialFeatures{{program._id}}" name="specialFeatures" class="form-control"
                        rows="10">{{{program.specialFeatures}}}</textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Age Range</label>
                        <input type="text" name="ageRange" class="form-control" placeholder="6 to 10"
                            value="{{program.ageRange}}">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Duration</label>
                        <input type="text" name="duration" class="form-control" placeholder="5 days / 4 nights"
                            value="{{program.duration}}">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Status</label>
                    <div class="form-selectgroup-boxes row mb-3 program-status">
                        <div class="col-lg-6">
                            <label class="form-selectgroup-item">
                                <input type="radio" name="status" value="active" class="form-selectgroup-input" {{#if
                                    (eq program.isActive true)}}checked{{/if}} />
                                <span class="form-selectgroup-label d-flex align-items-center p-3">
                                    <span class="me-3">
                                        <span class="form-selectgroup-check"></span>
                                    </span>
                                    <span class="form-selectgroup-label-content">
                                        <span class="form-selectgroup-title strong mb-1">Active</span>
                                        <span class="d-block text-secondary">Program is active.</span>
                                    </span>
                                </span>
                            </label>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-selectgroup-item">
                                <input type="radio" name="status" value="in-active" class="form-selectgroup-input" {{#if
                                    (eq program.isActive false)}}checked{{/if}} />
                                <span class="form-selectgroup-label d-flex align-items-center p-3">
                                    <span class="me-3">
                                        <span class="form-selectgroup-check"></span>
                                    </span>
                                    <span class="form-selectgroup-label-content">
                                        <span class="form-selectgroup-title strong mb-1">In active</span>
                                        <span class="d-block text-secondary">Program is in- active.</span>
                                    </span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <a href="#" class="btn btn-link link-secondary" data-bs-dismiss="modal">
                    Cancel
                </a>
                <a href="#" class="btn btn-primary ms-auto" onclick="updateProgram{{program._id}}(this)">
                    <i class="ti ti-device-floppy icon"></i>
                    Edit Program
                </a>
            </div>
        </div>
    </div>
</div>

<button href="#" class="btn btn-primary d-none" id="button-{{program._id}}" data-bs-toggle="modal"
    data-bs-target="#modal-{{program._id}}"></button>

<script>
    
    let programEditor{{program._id}}, featuresEditor{{program._id}};

    ClassicEditor
        .create(document.querySelector('#programDescription{{program._id}}'))
        .then(editor => {
            programEditor{{program._id}} = editor;
        })
        .catch(error => {
            console.error(error);
        });

    ClassicEditor
        .create(document.querySelector('#specialFeatures{{program._id}}'))
        .then(editor => {
            featuresEditor{{program._id}} = editor;
        })
        .catch(error => {
            console.error(error);
        });




    $("#programImageBox{{program._id}}").on("click", function () {
        $("#programImageInput{{program._id}}").click();
    });

    let previousImageUrl{{program._id}} = "{{program.imageUrl}}";

    $("#programImageInput{{program._id}}").on("change", function () {
        var file = this.files[0];
        if (!file) return;

        if (previousImageUrl{{program._id}}) {
            $.ajax({
                url: `/delete-program-image`,
                type: "POST",
                data: { imageUrl: previousImageUrl{{program._id}} },
                success: function (res) {
                    console.log("Previous image deleted");
                },
                error: function (err) {
                    console.log("Failed to delete previous image");
                }
            });
        }

        var formData = new FormData();
        formData.append("programImage", file);

        $.ajax({
            url: `/upload-program-image`,
            type: "POST",
            data: formData,
            contentType: false,
            processData: false,
            beforeSend: function () {
                $("#programImageBox{{program._id}}").html('<span style="font-size:1rem; color:#6c757d;">Uploading...</span>');
            },
            success: function (res) {
                $("#programImageBox{{program._id}}").html('<img src="' + res.imageUrl + '" style="height:100%; width:100%; object-fit:cover; border-radius:0.25rem;">');
                previousImageUrl{{program._id}} = res.imageUrl;
            },
            error: function (err) {
                $("#programImageBox{{program._id}}").html('<span style="font-size:2rem; color:#6c757d;">+</span>');
                alert("Image upload failed. Try again.");
            }
        });
    });

    const updateProgram{{program._id}} = (btn) => {
        const modal = $(btn).closest('.modal');
        const $btn = $(btn);

        const imageUrl = $("#programImageBox{{program._id}} img").attr("src");
        const title = modal.find('input[name="title"]').val().trim();
        const age = modal.find('input[name="ageRange"]').val().trim();
        const duration = modal.find('input[name="duration"]').val().trim();
        const description = programEditor{{program._id}} ? programEditor{{program._id}}.getData().trim() : '';
        const specialFeatures = featuresEditor{{program._id}} ? featuresEditor{{program._id}}.getData().trim() : '';
        const gender = modal.find('select[name="gender"]').val();
        const status = modal.find("input[name='status']:checked").val();

        const data = {
            imageUrl,
            title,
            age,
            duration,
            description,
            specialFeatures,
            gender,
            status,
        };

        const originalHtml = $btn.html();
        $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Saving...');

        $.ajax({
            url: `/programs/{{program._id}}`,
            type: "POST",
            data,
            success: function () {
                    alert("Program updated successfully");
                    // stay on the same page and refresh to reflect changes
                    window.location.reload();
                },
            error: function (err) {
                console.log(err);
                alert("Failed to update program");
            },
            complete: function () {
                $btn.prop('disabled', false).html(originalHtml);
            }
        });
    };
</script>